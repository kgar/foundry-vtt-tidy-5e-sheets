{
  "name": "tidy5e-sheet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "find-preloaded-images": "node find-preloaded-images.js",
    "prepare-dev": "node prepare-dist-for-dev.js",
    "dev": "npm run find-preloaded-images && npm run prepare-dev && vite",
    "build": "npm run find-preloaded-images && vite build && npm run check-errors",
    "build-watch": "vite build --watch",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check-watch": "svelte-check --watch --tsconfig ./tsconfig.json",
    "check-errors": "svelte-check --threshold error --tsconfig ./tsconfig.json",
    "check-errors-watch": "svelte-check --threshold error --watch --tsconfig ./tsconfig.json",
    "refresh-docs": "typedoc --options ./typedoc.json",
    "link-create": "node symlink-module-build-dir.js",
    "link-remove": "node symlink-module-build-dir.js --clean"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "fs-extra": "^11.3.5",
    "less": "^4.6.4",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "@melloware/coloris": "^0.25.0",
    "chroma-js": "^3.2.0"
  }
}
